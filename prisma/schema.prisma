// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  passwordHash     String // хеш, полученный с клиента
  description      String   @default("")
  avatar           String   @default("")
  gender           String   @default("")
  birthday         String   @default("")
  cityId           String
  subcategoriesIds Json     @default("[]") // храним как JSON-массив строк
  favorites        Json     @default("[]") // массив ID избранных пользователей
  offers           Offer[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("users")
}

model Category {
  id            String        @id @default(cuid())
  name          String
  type          String // 'business' | 'creative' | 'languages' | 'education' | 'home' | 'health'
  subcategories Subcategory[]

  @@map("categories")
}

model Subcategory {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  offers     Offer[]

  @@map("subcategories")
}

model City {
  id   String @id @default(cuid())
  name String

  @@map("cities")
}

model Offer {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  name          String
  subcategoryId String
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id])
  description   String
  images        Json        @default("[]") // массив строк (URL картинок)
  userLikedIds  Json        @default("[]") // массив ID пользователей, кто лайкнул
  createdAt     String // ISO строка, т.к. на фронте используется
  updatedAt     String?

  @@map("offers")
}
